{
  "name": "ojp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:down:volumes": "docker compose -f docker-compose.db.yml down -v",
    "db:generate": "node scripts/prisma-with-default-db-url.mjs generate",
    "db:push": "node scripts/prisma-with-default-db-url.mjs db push",
    "db:migrate:legacy-status": "node scripts/migrate-legacy-submission-status.mjs",
    "db:studio": "node scripts/prisma-with-default-db-url.mjs studio",
    "db:seed": "node scripts/prisma-with-default-db-url.mjs db seed",
    "db:prepare": "npm run db:up && npm run db:generate && npm run db:push && npm run db:seed",
    "worker:judge": "tsx scripts/judge-worker.ts",
    "template:problem-zip": "node scripts/create-problem-package-template.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/view": "^6.39.17",
    "@prisma/client": "^6.7.0",
    "@uiw/react-codemirror": "^4.25.8",
    "adm-zip": "^0.5.16",
    "jszip": "^3.10.1",
    "katex": "^0.16.38",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.0",
    "typescript": "^5"
  }
